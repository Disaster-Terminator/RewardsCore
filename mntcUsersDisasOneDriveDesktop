rscore

# 用户测试模式（3次搜索，稳定性验证）
rscore --user

# 开发模式（2次搜索，快速调试）
rscore --dev

# 无头模式（后台运行）
rscore --headless

# 组合使用
rscore --dev --headless
rscore --user --headless

# 仅桌面搜索
rscore --desktop-only

# 跳过搜索，仅测试任务系统
rscore --skip-search

# 跳过日常任务
rscore --skip-daily-tasks

# 模拟运行（不执行实际操作）
rscore --dry-run

# 测试通知功能
rscore --test-notification

# 使用特定浏览器
rscore --browser chrome
rscore --browser edge

# 指定配置文件
