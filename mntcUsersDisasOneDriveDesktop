    name: str = ""
    progress: int = 0
    max_progress: int = 0
    completed: bool = False

    @classmethod
    def from_dict(cls, data: dict[str, Any]) -> "PunchCard":
        """从字典创建实例"""
        data = _transform_dict(data)
        return cls(**_filter_dataclass_fields(data, cls))


@dataclass
class StreakPromotion:
