# 带覆盖率
pytest tests/unit/ -v --cov=src --cov-report=html --cov-report=term

# 并行测试（4 worker）
pytest tests/unit/ -v -n 4

# 显示最后失败的测试
pytest --last-failed

# 失败重启测试
pytest --failed-first
```

### 运行应用
```bash
