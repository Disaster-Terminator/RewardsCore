private normalizeAndDedupe(queries: string[]): string[] {
    const seen = new Set<string>()
    return queries.filter(q => {
        const norm = q.trim().replace(/\s+/g, ' ').toLowerCase()
        if (seen.has(norm)) return false
        seen.add(norm)
